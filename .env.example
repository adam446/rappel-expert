POSTGRES_USER=smart_user
POSTGRES_PASSWORD=smart_password
POSTGRES_DB=smart_reminders
# Dans Docker, le nom du service PostgreSQL est "db".
DATABASE_URL=postgresql+psycopg2://smart_user:smart_password@db:5432/smart_reminders
VITE_API_URL=http://localhost:8000
ADMIN_FULL_NAME=Administrateur
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
SECRET_KEY=replace-with-a-long-random-secret
FRONTEND_URL=http://localhost:5173

# Courriel utilise comme expediteur des reinitialisations de mot de passe.
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Rappel Expert
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=no-reply@example.com
SMTP_PASSWORD=replace-with-smtp-password
SMTP_USE_TLS=true
